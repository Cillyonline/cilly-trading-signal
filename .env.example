# App
APP_DOMAIN=localhost
# Use development or test for local work. Staging/production enable strict config guards.
ENVIRONMENT=development

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/cilly_trading_signal
# Production/staging must override every local placeholder below.
SECRET_KEY=change-this-secret-key
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-this-password
AUTH_COOKIE_NAME=cilly_session
# Must be true for HTTPS deployments.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=43200
TRADINGVIEW_WEBHOOK_SECRET=change-this-webhook-secret
# Production/staging must use exact origins, never wildcard values.
CORS_ORIGINS=["http://localhost:3000"]

# Telegram
# Explicit test delivery can use TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID directly.
# Automatic alert routing stays disabled unless TELEGRAM_ALERT_ROUTING_ENABLED=true.
# Keep this false for local development unless you intentionally test routing guards.
TELEGRAM_ALERT_ROUTING_ENABLED=false
# Required only for explicit Telegram test delivery and enabled alert routing.
# Use the bot token from BotFather and a known chat ID for the operator chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market data
# Provider sync is a guarded placeholder for future v1.4 work. It does not
# start provider calls or scheduling by itself.
MARKET_DATA_PROVIDER_SYNC_ENABLED=false
# Supported placeholders: alpha_vantage, twelve_data, yahoo_finance_unofficial, polygon, tiingo.
MARKET_DATA_PROVIDER=
# Required for key-based providers when MARKET_DATA_PROVIDER_SYNC_ENABLED=true.
# Not required for yahoo_finance_unofficial. Never commit real keys.
MARKET_DATA_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=/api

# Postgres
POSTGRES_USER=postgres
# Production/staging must not use postgres/password/change-this-password defaults.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cilly_trading_signal
