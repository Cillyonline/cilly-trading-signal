# App
APP_DOMAIN=localhost
# Use development or test for local work. Staging/production enable strict config guards.
ENVIRONMENT=development

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/cilly_trading_signal
# Production/staging must override every local placeholder below.
SECRET_KEY=change-this-secret-key
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-this-password
AUTH_COOKIE_NAME=cilly_session
# Must be true for HTTPS deployments.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=43200
TRADINGVIEW_WEBHOOK_SECRET=change-this-webhook-secret
# Production/staging must use exact origins, never wildcard values.
CORS_ORIGINS=["http://localhost:3000"]

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Postgres
POSTGRES_USER=postgres
# Production/staging must not use postgres/password/change-this-password defaults.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cilly_trading_signal
