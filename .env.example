# App
APP_DOMAIN=localhost
ENVIRONMENT=development

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/cilly_trading_signal
# Production/staging must override the local placeholder values below.
SECRET_KEY=change-this-secret-key
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-this-password
AUTH_COOKIE_NAME=cilly_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=43200
TRADINGVIEW_WEBHOOK_SECRET=change-this-webhook-secret
CORS_ORIGINS=["http://localhost:3000"]

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cilly_trading_signal
